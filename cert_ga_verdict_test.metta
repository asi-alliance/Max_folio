(= (margin $f $c $thresh) (- (* $f $c) $thresh))
(= (cert-verdict-from-margin $m internal) (if (> $m 0.3) ADMIT (if (> $m 0.1) QUARANTINE REJECT)))
(= (cert-verdict-from-margin $m action) (if (> $m 0.5) ADMIT (if (> $m 0.2) QUARANTINE REJECT)))
(= (cert-verdict-from-margin $m high_stakes) (if (> $m 0.7) ADMIT (if (> $m 0.4) QUARANTINE REJECT)))
(= (transform-belief $belief) $belief)
(= (cert-ga-verdict $f $c $context) (cert-verdict-from-margin (margin $f $c 0.2) $context))
!(cert-ga-verdict 0.8 0.7 internal)
!(cert-ga-verdict 0.4 0.5 action)
!(cert-ga-verdict 0.3 0.2 high_stakes)