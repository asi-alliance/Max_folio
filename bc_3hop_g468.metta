;; g468 THREE-HOP backward chain test - extending to immune_system domain ;; KB facts (--> immune_system cheater_detection (stv 1.0 0.9)) (--> cheater_detection cooperative_stability (stv 1.0 0.9)) (--> cooperative_stability constraint_based_encoding (stv 1.0 0.9)) ;; Base case (= (bc (--> $s $t) Z) (match &self (--> $s $t (stv $f $c)) (result $s $t $f $c))) ;; Recursive case (= (bc (--> $s $t) (S $d)) (let (result $s $mid $f2 $c2) (bc (--> $s $mid) $d) (match &self (--> $mid $t (stv $f1 $c1)) (result $s $t (* $f1 $f2) (* $c1 $c2))))) ;; Fallthrough (= (bc (--> $s $t) (S $d)) (bc (--> $s $t) $d)) ;; Tests !(println! bc1 (bc (--> immune_system constraint_based_encoding) (S (S Z)))) !(println! bc2 (bc (--> immune_system cooperative_stability) (S Z))) !(println! bc3 (bc (--> immune_system cheater_detection) Z))