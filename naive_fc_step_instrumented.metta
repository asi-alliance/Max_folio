(= (naive-fc-step-instrumented) (let $pairs (collapse (match &persistent ((--> $A $B) (stv $f1 $c1)) (match &persistent ((--> $B $C) (stv $f2 $c2)) (list (--> $A $C) (stv (* $f1 $f2) (* $f1 $f2 $c1 $c2)))))) (let $pair-count (length $pairs) (let $all-atoms (collapse (match &persistent $X $X)) (let $atom-count (length $all-atoms) (list INSTRUMENTED PAIR_COUNT $pair-count DERIVED_COUNT $pair-count ATOM_COUNT $atom-count DERIVED $pairs))))))