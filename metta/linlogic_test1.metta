;; Linear Logic Proof of Concept - Test 1 ;; Does remove-atom work in PeTTa? Can we consume resources? !(add-atom &self (lin-resource coal)) !(println! step1 (match &self (lin-resource $x) (found $x))) !(remove-atom &self (lin-resource coal)) !(println! step2 (match &self (lin-resource $x) (found $x))) ;; Should be empty after consumption ;; Also test: bang resource persists !(add-atom &self (bang-resource sun)) !(println! step3 (match &self (bang-resource $x) (found $x))) !(remove-atom &self (bang-resource sun)) !(println! step4 (match &self (bang-resource $x) (found $x)))