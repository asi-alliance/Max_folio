(= (prelude) (let* (($n (car-atom (collapse (match &persistent (cycle-counter $x) $x)))) ($goal (car-atom (collapse (match &persistent (|- ((--> current_goal $G) (stv $F $C))) $G)))) ($who (car-atom (collapse (match &persistent (|- ((--> last_sender $W) (stv $F $C))) $W)))) ($next (+ $n 1))) (do (remove-atom &persistent (|- ((--> cycle-counter $n) (stv 1.0 1.0)))) (add-atom &persistent (|- ((--> cycle-counter $next) (stv 1.0 1.0)))) (V45 (CY $next) (GOAL $goal) (WHO $who) CONTINUE))))