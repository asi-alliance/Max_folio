(add-atom &persistent (|- ((--> fc_last_mode ded) (stv 1.0 0.9))))(= (prelude) (let $goal-sensor (match &persistent (|- ((--> current_goal $g) (stv $f $c))) (list V44-GOAL $g)) (let $who-sensor (match &persistent (|- ((--> last_sender $w) (stv $f2 $c2))) (list V44-WHO $w)) (let $mode-sensor (match &persistent (|- ((--> fc_last_mode $m) (stv $f3 $c3))) (list V44-MODE $m)) (let $fc-result (match &persistent (|- ((--> fc_last_mode ded) (stv 1.0 0.9))) (fc-step4 ded) (match &persistent (|- ((--> fc_last_mode abd) (stv 1.0 0.9))) (fc-abd-step abd) (match &persistent (|- ((--> fc_last_mode ind) (stv 1.0 0.9))) (fc-ind-step ind) (fc-step4 ded)))) (list $goal-sensor $who-sensor $mode-sensor $fc-result)))))