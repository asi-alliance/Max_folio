(; disagreement_seek_wire.metta v2 — 2026-04-29)(; Wires Q_AMBIGUOUS detection → subtype split → NACE gate → evidence planner)(; Subtypes: ADMIT, Q_AMB_GENUINE (act), Q_AMB_RESOLVABLE (seek))(= (q-amb-class (stv $f $c)) (if (and (> $f 0.35) (and (< $f 0.65) (> $c 0.4))) Q_AMBIGUOUS ADMIT))(= (q-amb-subtype (stv $f $c)) (let* (($class (q-amb-class (stv $f $c))) ($gap (- 0.7 $c)) ($gate (if (> $gap 0.0) seek act)) ($sub (if (== $class Q_AMBIGUOUS) (if (== $gate seek) Q_AMB_RESOLVABLE Q_AMB_GENUINE) ADMIT))) $sub))(= (disagreement-seek $term (stv $f $c)) (let* (($sub (q-amb-subtype (stv $f $c))) ($plan (if (== $sub Q_AMB_RESOLVABLE) (let* (($gap (- 0.7 $c)) ($sources (sources-needed-est $gap)) ($action (best-action $term $gap 5))) (query-plan $term $action $sources $gap)) (if (== $sub Q_AMB_GENUINE) (accept-ambiguity $term (stv $f $c)) no-action-needed)))) (result $sub $plan)))